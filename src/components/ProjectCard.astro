---
// ProjectCard is now only used in index.astro inline.
// Kept as a minimal stub for any future use.
export interface Props {
  project: {
    name: string;
    display_name?: string;
    description?: string;
    version?: string;
    tags?: string[];
    repo_url?: string;
    status?: string;
    docs_updated_at?: string;
    changelog_updated_at?: string;
  };
}
const { project } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const status = project.status || 'active';
---

<a href={`${base}/projects/${project.name}`} class="pcard" data-status={status}>
  <div class="pcard-top">
    {status === 'active' ? (
      <span class="badge-active"><span class="badge-dot"></span>Active</span>
    ) : status === 'wip' ? (
      <span class="badge-wip">WIP</span>
    ) : (
      <span class="badge-archived">Arquivado</span>
    )}
    <span class="pcard-version">{project.version ? `v${project.version}` : '—'}</span>
  </div>
  <div class="pcard-name">{project.display_name || project.name}</div>
  <p class="pcard-desc">{project.description || ''}</p>
  <div class="pcard-tags">
    {(project.tags ?? []).map((tag: string) => (
      <span class="tag">{tag}</span>
    ))}
  </div>
</a>

<style>
  .pcard {
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: 12px; padding: 22px 24px; text-decoration: none;
    display: flex; flex-direction: column; gap: 12px;
    transition: all 200ms ease;
  }
  .pcard:hover { border-color: var(--border-bright); transform: translateY(-2px); }
  .pcard-top { display: flex; justify-content: space-between; align-items: flex-start; }
  .badge-active {
    background: oklch(68% 0.2 155 / 0.12); color: var(--success);
    border: 1px solid oklch(68% 0.2 155 / 0.25);
    border-radius: 6px; padding: 3px 10px; font-size: 11px; font-weight: 600;
    display: flex; align-items: center; gap: 5px;
  }
  .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .badge-wip {
    background: oklch(75% 0.18 70 / 0.12); color: var(--warn);
    border: 1px solid oklch(75% 0.18 70 / 0.25);
    border-radius: 6px; padding: 3px 10px; font-size: 11px; font-weight: 600;
  }
  .badge-archived {
    background: var(--bg-elevated); color: var(--fg-3);
    border: 1px solid var(--border-bright);
    border-radius: 6px; padding: 3px 10px; font-size: 11px; font-weight: 600;
  }
  .pcard-version { font-family: var(--font-mono); font-size: 11px; color: var(--fg-3); }
  .pcard-name { font-family: var(--font-body); font-weight: 600; font-size: 17px; color: var(--fg-1); line-height: 1.4; }
  .pcard-desc { font-size: 13px; color: var(--fg-2); line-height: 1.6; flex-grow: 1; margin: 0; }
  .pcard-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag {
    background: var(--bg-elevated); border: 1px solid var(--border-bright);
    color: var(--fg-2); padding: 2px 8px; border-radius: 9999px; font-size: 11px;
  }
</style>
