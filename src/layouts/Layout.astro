---
import { SITE_CONFIG } from '../config';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = SITE_CONFIG.siteDescription } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  <script type="module" is:inline>
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
    mermaid.initialize({
      startOnLoad: false,
      theme: 'dark',
      themeVariables: {
        background: '#08080f',
        primaryColor: 'oklch(65% 0.28 268)',
        primaryTextColor: '#f0f0fa',
        primaryBorderColor: 'oklch(55% 0.22 268)',
        lineColor: '#9898b8',
        secondaryColor: '#161625',
        tertiaryColor: '#08080f',
        edgeLabelBackground: '#0f0f1a',
        clusterBkg: '#161625',
        titleColor: '#f0f0fa',
      },
    });
    window.__mermaid = mermaid;
    document.dispatchEvent(new CustomEvent('mermaid:ready'));
  </script>
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg-base:       #08080f;
    --bg-surface:    #0f0f1a;
    --bg-elevated:   #161625;
    --bg-hover:      #1c1c2e;
    --border:        #1e1e35;
    --border-bright: #2d2d50;
    --accent:        oklch(65% 0.28 268);
    --accent-dim:    oklch(55% 0.22 268);
    --accent-bright: oklch(72% 0.3 268);
    --accent-muted:  oklch(65% 0.28 268 / 0.15);
    --accent-glow:   0 0 28px oklch(65% 0.28 268 / 0.35);
    --success:       oklch(68% 0.2 155);
    --danger:        oklch(62% 0.22 25);
    --warn:          oklch(75% 0.18 70);
    --fg-1:          #f0f0fa;
    --fg-2:          #9898b8;
    --fg-3:          #55557a;
    --fg-4:          #35355a;
    --font-display:  'Syne', sans-serif;
    --font-body:     'DM Sans', sans-serif;
    --font-mono:     'JetBrains Mono', monospace;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: var(--bg-base);
    color: var(--fg-1);
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
  }

  ::-webkit-scrollbar { width: 6px; background: var(--bg-base); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  a { color: var(--accent); text-decoration: none; }

  /* Mermaid diagram containers */
  .mermaid {
    background: rgba(15, 15, 26, 0.6);
    border-radius: 10px;
    padding: 24px;
    border: 1px solid var(--border);
    overflow-x: auto;
    margin: 24px 0;
    font-size: initial;
    line-height: initial;
  }
  .mermaid svg { max-width: 100%; height: auto; }

  /* Prose overrides for the design system */
  .prose pre {
    background: #0a0a14 !important;
    border: 1px solid var(--border) !important;
    border-radius: 8px !important;
  }
  .prose code:not(pre code) {
    color: var(--success);
    background: oklch(68% 0.2 155 / 0.1);
    border: 1px solid oklch(68% 0.2 155 / 0.2);
    border-radius: 4px;
    padding: 1px 6px;
    font-size: 0.85em;
  }
  .prose code:not(pre code)::before,
  .prose code:not(pre code)::after { content: none; }
  .prose h1 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 26px;
    line-height: 1.3;
    color: var(--fg-1);
    letter-spacing: -0.02em;
    margin-top: 0;
    margin-bottom: 20px;
  }
  .prose h2 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 22px;
    line-height: 1.5;
    color: var(--fg-1);
    letter-spacing: -0.02em;
    margin-top: 36px;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }
  .prose h3 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 16px;
    line-height: 1.5;
    color: var(--fg-1);
    margin-top: 24px;
    margin-bottom: 10px;
  }
  .prose p { font-size: 14px; color: var(--fg-2); line-height: 1.75; margin-bottom: 14px; }
  .prose ul, .prose ol { color: var(--fg-2); font-size: 14px; line-height: 2; }
  .prose blockquote {
    border-left-color: var(--accent);
    background: oklch(65% 0.28 268 / 0.06);
    border-radius: 0 8px 8px 0;
  }
  .prose table th { background: var(--bg-surface); color: var(--fg-1); }
  .prose table tr:nth-child(even) { background: rgba(15,15,26,0.4); }
  .prose hr { border-color: var(--border); }
  .prose a { color: var(--accent); }
  .prose a:hover { color: var(--accent-bright); }

  /* Code block language label */
  .prose pre { position: relative !important; padding-top: 36px !important; }
  .code-lang-label {
    position: absolute; top: 0; left: 0; right: 0;
    padding: 5px 14px;
    background: #0f0f1a; border-bottom: 1px solid var(--border);
    font-family: var(--font-mono); font-size: 10px; color: var(--fg-4);
    text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600;
    border-radius: 8px 8px 0 0;
  }

  /* Changelog version entries */
  .changelog-content h2 { display: flex; align-items: center; gap: 12px; }
  .changelog-content h2::before { content: 'v'; color: var(--accent); font-family: var(--font-mono); font-size: 14px; }
</style>
