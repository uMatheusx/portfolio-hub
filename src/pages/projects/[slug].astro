---
import Layout from '../../layouts/Layout.astro';
import { readdirSync, readFileSync, existsSync } from 'fs';
import { join } from 'path';
import { marked } from 'marked';

export function getStaticPaths() {
  try {
    const dir = join(process.cwd(), 'projects');
    return readdirSync(dir)
      .filter((f: string) => f.endsWith('.json'))
      .map((f: string) => ({ params: { slug: f.replace('.json', '') } }));
  } catch { return []; }
}

const { slug } = Astro.params as { slug: string };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

type Project = {
  name: string;
  display_name?: string;
  description?: string;
  version?: string;
  tags?: string[];
  repo_url?: string;
  status?: string;
  docs_updated_at?: string;
  changelog_updated_at?: string;
};

const project: Project = JSON.parse(
  readFileSync(join(process.cwd(), 'projects', `${slug}.json`), 'utf-8')
);

// ── Icon system ────────────────────────────────────────────────────
type IconPaths = string | string[];

const ICONS: Record<string, IconPaths> = {
  home:         'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z',
  layers:       ['M12 2L2 7l10 5 10-5-10-5z','M2 17l10 5 10-5','M2 12l10 5 10-5'],
  terminal:     ['M4 17L10 11 4 5','M12 19H20'],
  code:         ['M16 18L22 12 16 6','M8 6L2 12 8 18'],
  zap:          'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  file:         ['M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z','M14 2v6h6'],
  book:         ['M4 19.5A2.5 2.5 0 0 1 6.5 17H20','M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z'],
  changelog:    ['M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z','M14 2v6h6','M16 13H8','M16 17H8','M10 9H8'],
  clock:        ['M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z','M12 6v6l4 2'],
  shield:       'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  database:     ['M12 2c-5 0-9 1.34-9 3s4 3 9 3 9-1.34 9-3-4-3-9-3z','M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5','M3 12c0 1.66 4 3 9 3s9-1.34 9-3'],
  settings:     ['M4 21v-7','M4 10V3','M12 21v-9','M12 8V3','M20 21v-5','M20 12V3','M1 14h6','M9 8h6','M17 16h6'],
  list:         ['M8 6h13','M8 12h13','M8 18h13','M3 6h.01','M3 12h.01','M3 18h.01'],
  star:         'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
  link:         ['M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71','M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71'],
  chart:        ['M18 20V10','M12 20V4','M6 20v-6'],
  package:      ['M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z','M3.27 6.96L12 12.01l8.73-5.05','M12 22.08V12'],
  github:       'M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22',
};

// Auto-detect icon from filename when no frontmatter icon is set
const ICON_AUTO: Record<string, string> = {
  readme:           'home',
  overview:         'home',
  visao:            'home',
  architecture:     'layers',
  arch:             'layers',
  arquitetura:      'layers',
  usage:            'terminal',
  'como-usar':      'terminal',
  'getting-started':'terminal',
  setup:            'settings',
  config:           'settings',
  configuration:    'settings',
  api:              'zap',
  reference:        'list',
  referencias:      'list',
  security:         'shield',
  seguranca:        'shield',
  database:         'database',
  data:             'database',
  changelog:        'clock',
  changes:          'clock',
  releases:         'clock',
  contributing:     'star',
  deploy:           'package',
  deployment:       'package',
  monitoring:       'chart',
  metrics:          'chart',
  github:           'github',
  links:            'link',
  code:             'code',
  examples:         'code',
  exemplos:         'code',
};

function getAutoIcon(id: string): string {
  const clean = id.toLowerCase().replace(/^\d+-/, '').replace(/[_]/g, '-');
  for (const [key, icon] of Object.entries(ICON_AUTO)) {
    if (clean === key || clean.startsWith(key) || clean.endsWith(key) || clean.includes(key)) return icon;
  }
  return 'file';
}

// Parse YAML frontmatter — extracts `icon:` and optional `title:` fields
function parseFrontmatter(raw: string): { icon?: string; title?: string; stripped: string } {
  const match = raw.match(/^---\r?\n([\s\S]*?)\r?\n---\r?\n?([\s\S]*)$/);
  if (!match) return { stripped: raw };
  const yaml = match[1];
  const stripped = match[2];
  const icon  = yaml.match(/^icon:\s*(.+)$/m)?.[1]?.trim();
  const title = yaml.match(/^title:\s*(.+)$/m)?.[1]?.trim();
  return { icon, title, stripped };
}

// ── Docs ──────────────────────────────────────────────────────────
type DocFile = { id: string; label: string; html: string; icon: string };

const DOC_LABELS: Record<string, string> = {
  README: 'Visão Geral',
  architecture: 'Arquitetura',
  usage: 'Como Usar',
  api: 'API Reference',
};
const DOC_ORDER = ['README', 'architecture', 'usage', 'api'];
const ALL_CAPS = new Set(['api', 'faq', 'sdk', 'cli', 'iam', 'sql', 'ci', 'cd']);

function toLabel(filename: string, frontmatterTitle?: string): string {
  if (frontmatterTitle) return frontmatterTitle;
  const id = filename.replace(/^\d+-/, '');
  if (DOC_LABELS[id]) return DOC_LABELS[id];
  if (ALL_CAPS.has(id.toLowerCase())) return id.toUpperCase();
  return id.replace(/[-_]/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
}

let docs: DocFile[] = [];
const docsDir = join(process.cwd(), 'docs', slug);
if (existsSync(docsDir)) {
  const files = readdirSync(docsDir)
    .filter((f: string) => f.endsWith('.md'))
    .sort((a: string, b: string) => {
      const [aBase, bBase] = [a, b].map((f: string) => f.replace('.md', ''));
      const [aNum, bNum] = [aBase, bBase].map((s: string) => parseInt(s.match(/^(\d+)/)?.[1] ?? ''));
      if (!isNaN(aNum) || !isNaN(bNum)) return (isNaN(aNum) ? 999 : aNum) - (isNaN(bNum) ? 999 : bNum);
      const [aOrd, bOrd] = [aBase, bBase].map((s: string) => DOC_ORDER.indexOf(s));
      if (aOrd !== bOrd) return (aOrd === -1 ? 999 : aOrd) - (bOrd === -1 ? 999 : bOrd);
      return aBase.localeCompare(bBase);
    });

  docs = files.map((f: string) => {
    const id = f.replace('.md', '');
    const raw = readFileSync(join(docsDir, f), 'utf-8');
    const { icon, title, stripped } = parseFrontmatter(raw);
    return {
      id,
      label: toLabel(id, title),
      html:  String(marked.parse(stripped)),
      icon:  icon && ICONS[icon] ? icon : getAutoIcon(id),
    };
  });
}

// ── Changelog ─────────────────────────────────────────────────────
let changelogHtml = '';
const changelogPath = join(process.cwd(), 'changelogs', `${slug}.md`);
if (existsSync(changelogPath)) {
  changelogHtml = String(marked.parse(readFileSync(changelogPath, 'utf-8')));
}

const status = project.status || 'active';
---

<Layout title={`${project.display_name ?? slug} · Portfolio`}>

  <!-- ── STICKY HEADER ───────────────────────────────────── -->
  <header id="docs-header">
    <div class="header-inner">
      <div class="header-left">
        <a href={`${base}/`} class="back-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Portfolio
        </a>
        <span class="breadcrumb-sep">/</span>
        <div class="header-project">
          <svg width="18" height="18" viewBox="0 0 48 48" fill="none">
            <path d="M24 4 L42 14 L42 34 L24 44 L6 34 L6 14 Z" stroke="var(--accent)" stroke-width="2"/>
            <path d="M15 32 L15 17 L24 27 L33 17 L33 32" stroke="#f0f0fa" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="24" cy="36" r="2" fill="var(--accent)"/>
          </svg>
          <span class="header-project-name">{project.display_name ?? slug}</span>
          <span class="header-version">{project.version ? `v${project.version}` : '—'}</span>
          {status === 'active' && (
            <span class="header-badge-active">
              <span class="badge-pulse"></span>Active
            </span>
          )}
          {status === 'wip' && (
            <span class="header-badge-wip">WIP</span>
          )}
        </div>
      </div>
      <div class="header-right">
        {project.repo_url && (
          <a href={project.repo_url} target="_blank" rel="noopener" class="header-gh-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            GitHub
          </a>
        )}
      </div>
    </div>
  </header>

  <!-- ── BODY LAYOUT ─────────────────────────────────────── -->
  <div class="docs-body">

    <!-- SIDEBAR -->
    <aside class="docs-sidebar">
      {docs.length > 0 && (
        <div class="sidebar-group">
          <div class="sidebar-label">Documentação</div>
          {docs.map((doc, i) => {
            const paths = ICONS[doc.icon] ?? ICONS['file'];
            return (
              <button
                class={`sidebar-btn ${i === 0 ? 'sidebar-active' : ''}`}
                data-doc={doc.id}
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;flex-shrink:0;">
                  {Array.isArray(paths) ? paths.map(d => <path d={d}/>) : <path d={paths}/>}
                </svg>
                {doc.label}
              </button>
            );
          })}
        </div>
      )}
      {changelogHtml && (
        <div class="sidebar-group">
          <div class="sidebar-label">Releases</div>
          {(() => {
            const paths = ICONS['clock'];
            return (
              <button class={`sidebar-btn ${docs.length === 0 ? 'sidebar-active' : ''}`} data-doc="__changelog">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;flex-shrink:0;">
                  {Array.isArray(paths) ? paths.map(d => <path d={d}/>) : <path d={paths}/>}
                </svg>
                Changelog
              </button>
            );
          })()}
        </div>
      )}
    </aside>

    <!-- MAIN CONTENT -->
    <main class="docs-main">

      <!-- Tab pills (mirrors sidebar) -->
      <div class="tab-pills">
        {docs.map((doc, i) => {
          const paths = ICONS[doc.icon] ?? ICONS['file'];
          return (
            <button
              class={`tab-pill ${i === 0 ? 'tab-pill-active' : ''}`}
              data-tab={doc.id}
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;">
                {Array.isArray(paths) ? paths.map(d => <path d={d}/>) : <path d={paths}/>}
              </svg>
              {doc.label}
            </button>
          );
        })}
        {changelogHtml && (() => {
          const paths = ICONS['clock'];
          return (
            <button
              class={`tab-pill ${docs.length === 0 ? 'tab-pill-active' : ''}`}
              data-tab="__changelog"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;">
                {Array.isArray(paths) ? paths.map(d => <path d={d}/>) : <path d={paths}/>}
              </svg>
              Changelog
            </button>
          );
        })()}
      </div>

      <!-- Doc panels -->
      {docs.map((doc, i) => (
        <div class={`doc-panel ${i === 0 ? '' : 'hidden'}`} data-panel={doc.id}>
          <div class="prose prose-invert" set:html={doc.html} />
        </div>
      ))}

      <!-- Changelog panel -->
      {changelogHtml && (
        <div
          class={`doc-panel changelog-content ${docs.length === 0 ? '' : 'hidden'}`}
          data-panel="__changelog"
        >
          <div class="prose prose-invert" set:html={changelogHtml} />
        </div>
      )}

      {docs.length === 0 && !changelogHtml && (
        <div class="empty-state">
          <p class="empty-msg">Sem conteúdo ainda.</p>
          <p class="empty-hint">Adicione arquivos em <code>docs/{slug}/</code> ou <code>changelogs/{slug}.md</code></p>
        </div>
      )}

      {(project.docs_updated_at || project.changelog_updated_at) && (
        <div class="timestamps">
          {project.docs_updated_at && (
            <span>docs: {new Date(project.docs_updated_at).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}</span>
          )}
          {project.changelog_updated_at && (
            <span>release: {new Date(project.changelog_updated_at).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}</span>
          )}
        </div>
      )}

    </main>
  </div>

</Layout>

<style>
  /* ── HEADER ── */
  #docs-header {
    position: sticky; top: 0; z-index: 50;
    background: rgba(8, 8, 15, 0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    max-width: 1100px; margin: 0 auto;
    padding: 0 24px; height: 60px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .header-left {
    display: flex; align-items: center; gap: 12px; min-width: 0;
  }
  .back-link {
    display: flex; align-items: center; gap: 6px;
    color: var(--fg-3); font-size: 13px; transition: color 150ms;
    flex-shrink: 0;
  }
  .back-link:hover { color: var(--fg-1); }
  .breadcrumb-sep { color: var(--border); flex-shrink: 0; }
  .header-project {
    display: flex; align-items: center; gap: 8px; min-width: 0;
  }
  .header-project-name {
    font-family: var(--font-display); font-weight: 700;
    font-size: 14px; color: var(--fg-1); letter-spacing: -0.01em;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .header-version {
    font-family: var(--font-mono); font-size: 11px; color: var(--fg-3);
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: 5px; padding: 1px 8px; flex-shrink: 0;
  }
  .header-badge-active {
    background: oklch(68% 0.2 155 / 0.12); color: var(--success);
    border: 1px solid oklch(68% 0.2 155 / 0.25);
    border-radius: 6px; padding: 2px 8px; font-size: 11px; font-weight: 600;
    display: flex; align-items: center; gap: 4px; flex-shrink: 0;
  }
  .badge-pulse {
    width: 5px; height: 5px; border-radius: 50%;
    background: currentColor; display: inline-block;
  }
  .header-badge-wip {
    background: oklch(75% 0.18 70 / 0.12); color: var(--warn);
    border: 1px solid oklch(75% 0.18 70 / 0.25);
    border-radius: 6px; padding: 2px 8px; font-size: 11px; font-weight: 600;
    flex-shrink: 0;
  }
  .header-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  .header-gh-btn {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--fg-2);
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: 7px; padding: 6px 12px; transition: all 150ms;
    white-space: nowrap;
  }
  .header-gh-btn:hover { color: var(--fg-1); border-color: var(--border-bright); }

  /* ── BODY LAYOUT ── */
  .docs-body {
    display: flex; max-width: 1100px;
    margin: 0 auto; padding: 0 24px;
  }

  /* ── SIDEBAR ── */
  .docs-sidebar {
    width: 210px; flex-shrink: 0;
    position: sticky; top: 60px;
    height: calc(100vh - 60px); overflow-y: auto;
    padding: 24px 16px 24px 0;
    border-right: 1px solid var(--border);
  }
  .sidebar-group { margin-bottom: 24px; }
  .sidebar-label {
    font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--fg-4);
    margin-bottom: 6px; padding-left: 10px;
  }
  .sidebar-btn {
    width: 100%; text-align: left;
    background: none; border: none; border-radius: 7px;
    padding: 7px 10px; color: var(--fg-2);
    cursor: pointer; font-size: 13px; font-weight: 400;
    display: flex; align-items: center; gap: 8px;
    transition: all 150ms; font-family: var(--font-body);
    margin-bottom: 2px; line-height: 1.5;
  }
  .sidebar-btn:hover { color: var(--fg-1); background: var(--bg-elevated); }
  .sidebar-active {
    background: oklch(65% 0.28 268 / 0.1) !important;
    color: var(--accent) !important;
    font-weight: 600 !important;
  }

  /* ── MAIN CONTENT ── */
  .docs-main {
    flex: 1; padding: 28px 0 80px 36px; min-width: 0;
  }

  /* ── TAB PILLS ── */
  .tab-pills {
    display: flex; gap: 6px; margin-bottom: 24px; flex-wrap: wrap;
  }
  .tab-pill {
    background: var(--bg-surface); color: var(--fg-2);
    border: 1px solid var(--border);
    padding: 5px 12px; border-radius: 9999px;
    font-size: 12px; font-weight: 600; cursor: pointer;
    font-family: var(--font-body); transition: all 150ms;
    display: flex; align-items: center; gap: 5px;
  }
  .tab-pill:hover { border-color: var(--border-bright); }
  .tab-pill-active {
    background: var(--accent) !important;
    color: #fff !important;
    border-color: transparent !important;
    box-shadow: 0 0 14px oklch(65% 0.28 268 / 0.28);
  }

  /* ── PANELS ── */
  .hidden { display: none !important; }

  /* ── EMPTY STATE ── */
  .empty-state {
    border: 1px dashed var(--border); border-radius: 16px;
    padding: 72px 24px; text-align: center;
  }
  .empty-msg { font-size: 13px; color: var(--fg-3); font-family: var(--font-mono); }
  .empty-hint { font-size: 12px; color: var(--fg-4); margin-top: 8px; }
  .empty-hint code { color: var(--accent); font-family: var(--font-mono); }

  /* ── TIMESTAMPS ── */
  .timestamps {
    display: flex; flex-wrap: wrap; gap: 20px;
    font-size: 11px; font-family: var(--font-mono); color: var(--fg-4);
    border-top: 1px solid var(--border);
    padding-top: 20px; margin-top: 40px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .docs-sidebar { display: none; }
    .docs-main { padding-left: 0; }
    .header-project-name { max-width: 120px; }
    .header-badge-active, .header-badge-wip { display: none; }
  }
</style>

<script>
  // --- Mermaid helpers ---
  function convertMermaidBlocks() {
    document.querySelectorAll('code.language-mermaid').forEach(el => {
      const pre = el.parentElement;
      if (!pre) return;
      const div = document.createElement('div');
      div.className = 'mermaid not-prose';
      div.textContent = el.textContent || '';
      pre.replaceWith(div);
    });
  }

  async function renderMermaidIn(container: Element) {
    const m = (window as any).__mermaid;
    if (!m) return;
    const nodes = Array.from(container.querySelectorAll('.mermaid:not([data-processed])'));
    if (nodes.length === 0) return;
    try { await m.run({ nodes }); } catch {}
  }

  function onMermaidReady(cb: () => void) {
    if ((window as any).__mermaid) { cb(); return; }
    document.addEventListener('mermaid:ready', cb, { once: true });
  }

  // --- Panel switching (syncs sidebar + tab pills + hash) ---
  function activatePanel(id: string) {
    document.querySelectorAll<HTMLElement>('.doc-panel').forEach(el => el.classList.add('hidden'));
    const panel = document.querySelector<HTMLElement>(`[data-panel="${id}"]`);
    if (panel) {
      panel.classList.remove('hidden');
      onMermaidReady(() => renderMermaidIn(panel));
    }
    document.querySelectorAll<HTMLElement>('.sidebar-btn').forEach(btn => btn.classList.remove('sidebar-active'));
    document.querySelector<HTMLElement>(`[data-doc="${id}"]`)?.classList.add('sidebar-active');
    document.querySelectorAll<HTMLElement>('.tab-pill').forEach(btn => btn.classList.remove('tab-pill-active'));
    document.querySelector<HTMLElement>(`[data-tab="${id}"]`)?.classList.add('tab-pill-active');
    history.replaceState(null, '', `#${id}`);
  }

  document.querySelectorAll<HTMLButtonElement>('.sidebar-btn').forEach(btn => {
    btn.addEventListener('click', () => activatePanel(btn.dataset.doc!));
  });
  document.querySelectorAll<HTMLButtonElement>('.tab-pill').forEach(btn => {
    btn.addEventListener('click', () => activatePanel(btn.dataset.tab!));
  });

  convertMermaidBlocks();

  const hash = window.location.hash.replace('#', '');
  const firstDocBtn = document.querySelector<HTMLButtonElement>('.sidebar-btn');
  const initialId = hash || firstDocBtn?.dataset.doc || '__changelog';
  activatePanel(initialId);

  onMermaidReady(() => {
    const activePanel = document.querySelector<HTMLElement>('.doc-panel:not(.hidden)');
    if (activePanel) renderMermaidIn(activePanel);
  });
</script>
