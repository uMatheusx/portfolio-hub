---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import BlogCard from '../components/BlogCard.astro';
import { readdirSync, readFileSync } from 'fs';
import { join } from 'path';
import { SITE_CONFIG } from '../config';

type Project = {
  name: string;
  display_name?: string;
  description?: string;
  version?: string;
  tags?: string[];
  repo_url?: string;
  status?: string;
  docs_updated_at?: string;
  changelog_updated_at?: string;
};

function parseFrontmatter(raw: string): Record<string, string | string[]> {
  const match = raw.match(/^---\r?\n([\s\S]*?)\r?\n---/);
  if (!match) return {};
  const yaml = match[1];
  const result: Record<string, string | string[]> = {};
  for (const line of yaml.split('\n')) {
    const colonIdx = line.indexOf(':');
    if (colonIdx === -1) continue;
    const key = line.slice(0, colonIdx).trim();
    const val = line.slice(colonIdx + 1).trim();
    if (val.startsWith('[')) {
      result[key] = val.slice(1, -1).split(',').map((s: string) => s.trim().replace(/^["']|["']$/g, ''));
    } else {
      result[key] = val.replace(/^["']|["']$/g, '');
    }
  }
  return result;
}

type BlogPost = { slug: string; title: string; description?: string; date: string; tags?: string[] };

let recentPosts: BlogPost[] = [];
try {
  const blogDir = join(process.cwd(), 'content', 'blog');
  recentPosts = readdirSync(blogDir)
    .filter((f: string) => f.endsWith('.md'))
    .map((f: string) => {
      const raw = readFileSync(join(blogDir, f), 'utf-8');
      const fm = parseFrontmatter(raw);
      return {
        slug: f.replace('.md', ''),
        title: String(fm.title || f.replace('.md', '')),
        description: fm.description ? String(fm.description) : undefined,
        date: String(fm.date || ''),
        tags: Array.isArray(fm.tags) ? fm.tags : [],
      };
    })
    .sort((a: BlogPost, b: BlogPost) => new Date(b.date).getTime() - new Date(a.date).getTime())
    .slice(0, 3);
} catch {}

let projects: Project[] = [];
try {
  const dir = join(process.cwd(), 'projects');
  const files = readdirSync(dir).filter((f: string) => f.endsWith('.json'));
  projects = files
    .map((f: string) => JSON.parse(readFileSync(join(dir, f), 'utf-8')) as Project)
    .sort((a: Project, b: Project) => new Date(b.changelog_updated_at || 0).getTime() - new Date(a.changelog_updated_at || 0).getTime());
} catch {}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function relativeTime(iso: string | undefined): string {
  if (!iso) return '';
  const days = Math.floor((Date.now() - new Date(iso).getTime()) / 86400000);
  if (days === 0) return 'hoje';
  if (days === 1) return 'ontem';
  if (days < 7) return `${days} dias atrás`;
  if (days < 30) return `${Math.floor(days / 7)} sem. atrás`;
  if (days < 365) return `${Math.floor(days / 30)} ${Math.floor(days / 30) > 1 ? 'meses' : 'mês'} atrás`;
  return `${Math.floor(days / 365)} ano${Math.floor(days / 365) > 1 ? 's' : ''} atrás`;
}
---

<Layout title={SITE_CONFIG.siteName}>

  <!-- ── NAV ─────────────────────────────────────────────── -->
  <Nav transparent />

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section id="hero">
    <div class="hero-inner">
      <div class="hero-overline">
        <div class="overline-bar"></div>
        <span>Engenheiro de Software</span>
      </div>
      <h1 class="hero-h1">
        Matheus<br/>
        <span class="hero-accent">Azevedo</span>
      </h1>
      <p class="hero-sub">
        Construo sistemas que funcionam em produção — não só no README. Cada projeto tem documentação real, GitOps, e releases rastreáveis.
      </p>
      <div class="hero-ctas">
        <a href="#projects" class="cta-primary">
          Ver projetos
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:15px;height:15px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#about" class="cta-secondary">Sobre mim</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-num">{projects.length || '—'}</div>
          <div class="stat-label">Projetos</div>
        </div>
        <div class="stat">
          <div class="stat-num">3+</div>
          <div class="stat-label">Anos</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PROJECTS ─────────────────────────────────────────── -->
  <section id="projects" class="section-projects">
    <div class="section-header">
      <div>
        <div class="section-overline">Projetos</div>
        <h2 class="section-h2">O que eu construí</h2>
      </div>
      <div class="filter-pills" id="filter-pills">
        <button class="pill pill-active" data-filter="all">Todos</button>
        <button class="pill" data-filter="active">Active</button>
        <button class="pill" data-filter="wip">WIP</button>
        <button class="pill" data-filter="archived">Arquivados</button>
      </div>
    </div>

    {projects.length > 0 ? (
      <div class="projects-grid" id="projects-grid">
        {projects.map(project => {
          const status = project.status || 'active';
          const updated = relativeTime(project.changelog_updated_at || project.docs_updated_at);
          return (
            <a
              href={`${base}/projects/${project.name}`}
              class="pcard"
              data-status={status}
            >
              <div class="pcard-top">
                {status === 'active' ? (
                  <span class="badge-active">
                    <span class="badge-dot"></span>Active
                  </span>
                ) : status === 'wip' ? (
                  <span class="badge-wip">WIP</span>
                ) : (
                  <span class="badge-archived">Arquivado</span>
                )}
                <span class="pcard-version">{project.version ? `v${project.version}` : '—'}</span>
              </div>
              <div class="pcard-name">{project.display_name || project.name}</div>
              <p class="pcard-desc">{project.description || ''}</p>
              <div class="pcard-tags">
                {(project.tags ?? []).map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <div class="pcard-footer">
                <span class="pcard-updated">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:11px;height:11px;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {updated}
                </span>
                <span class="pcard-link">
                  Ver docs
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="empty-state">
        <p class="empty-msg">Nenhum projeto ainda.</p>
        <p class="empty-hint">Adicione um arquivo em <code>projects/meu-projeto.json</code></p>
      </div>
    )}
  </section>

  <!-- ── ABOUT ─────────────────────────────────────────────── -->
  <section id="about" class="section-about">

    <!-- Bio -->
    <div class="about-bio-wrap">
      <div class="about-bio">
        <div class="section-overline">Sobre</div>
        <h2 class="about-h2">Feito com obsessão<br/>por detalhe</h2>
        <!-- Edite este parágrafo com seu texto pessoal -->
        <p class="about-p">
          Sou engenheiro de software focado em infraestrutura e automação. Acredito que um bom projeto não termina no commit — ele tem documentação real, releases rastreáveis e um pipeline que funciona enquanto você dorme.
        </p>
        <a href={`https://github.com/${SITE_CONFIG.githubUser}`} target="_blank" rel="noopener" class="about-cta">
          <svg viewBox="0 0 24 24" fill="currentColor" style="width:15px;height:15px;"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
      </div>
    </div>

    <!-- Stack com ícones reais, agrupados por segmento -->
    <div class="stack-section">
      <div class="stack-section-header">
        <div class="stack-section-overline">Stack</div>
        <div class="stack-section-line"></div>
      </div>
      <div class="stack-groups">
        {([
          {
            cat: 'Backend',
            items: [
              { name: 'Go',         icon: 'go',           color: '00ADD8' },
              { name: 'Rust',       icon: 'rust',         color: 'CE422B' },
              { name: 'TypeScript', icon: 'typescript',   color: '3178C6' },
              { name: 'Python',     icon: 'python',       color: '3776AB' },
            ],
          },
          {
            cat: 'Infra',
            items: [
              { name: 'Kubernetes', icon: 'kubernetes',   color: '326CE5' },
              { name: 'Terraform',  icon: 'terraform',    color: '7B42BC' },
              { name: 'Docker',     icon: 'docker',       color: '2496ED' },
              { name: 'AWS Certified SAA-C03',        icon: 'amazonaws',    color: 'FF9900' },
            ],
          },
          {
            cat: 'Data',
            items: [
              { name: 'PostgreSQL', icon: 'postgresql',   color: '336791' },
              { name: 'Redis',      icon: 'redis',        color: 'FF4438' },
              { name: 'ClickHouse', icon: 'clickhouse',   color: 'FFCC01' },
              { name: 'NATS',       icon: 'natsdotio',    color: '27AAE1' },
            ],
          },
          {
            cat: 'Observability',
            items: [
              { name: 'Prometheus',    icon: 'prometheus',    color: 'E6522C' },
              { name: 'Grafana',       icon: 'grafana',       color: 'F46800' },
              { name: 'OpenTelemetry', icon: 'opentelemetry', color: '425CC7' },
            ],
          },
        ] as { cat: string; items: { name: string; icon: string; color: string }[] }[]).map(group => (
          <div class="stack-group">
            <div class="stack-group-cat">{group.cat}</div>
            <div class="tech-cards">
              {group.items.map(tech => (
                <div class="tech-card" style={`--brand:#${tech.color}`}>
                  <div class="tech-icon-wrap">
                    <img
                      src={`https://cdn.simpleicons.org/${tech.icon}/${tech.color}`}
                      alt={tech.name}
                      width="28"
                      height="28"
                      loading="lazy"
                      draggable="false"
                    />
                  </div>
                  <span class="tech-name">{tech.name}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

  </section>

  <!-- ── EXPERIENCE ─────────────────────────────────────────── -->
  <section id="experience" class="section-experience">
    <div class="section-header">
      <div>
        <div class="section-overline">Experiência</div>
        <h2 class="section-h2">Jornada profissional</h2>
      </div>
    </div>

    <div class="exp-timeline">

      <!-- Entry: current role -->
      <div class="exp-entry" data-exp>
        <div class="exp-year">
          <div class="exp-year-row">
            <span class="exp-year-num">2023</span>
            <span class="exp-year-month">Mar</span>
          </div>
          <span class="exp-year-label exp-year-now">— hoje</span>
        </div>
        <div class="exp-connector">
          <div class="exp-dot exp-dot-active">
            <div class="exp-dot-ring"></div>
          </div>
          <div class="exp-line"></div>
        </div>
        <div class="exp-card">
          <div class="exp-card-glow"></div>
          <div class="exp-card-top">
            <div class="exp-role">Senior Software Engineer</div>
            <div class="exp-company-name">Empresa Atual</div>
          </div>
          <p class="exp-desc">Liderança técnica em projetos críticos de infraestrutura, arquitetura de sistemas distribuídos e mentoria de equipe.</p>
          <div class="exp-stack">
            <span class="exp-chip">Go</span>
            <span class="exp-chip">Kubernetes</span>
            <span class="exp-chip">AWS</span>
            <span class="exp-chip">Terraform</span>
          </div>
        </div>
      </div>

      <!-- Entry: mid role -->
      <div class="exp-entry" data-exp>
        <div class="exp-year">
          <div class="exp-year-row">
            <span class="exp-year-num">2021</span>
            <span class="exp-year-month">Jan</span>
          </div>
          <span class="exp-year-label">— 2023 Mar</span>
        </div>
        <div class="exp-connector">
          <div class="exp-dot"></div>
          <div class="exp-line"></div>
        </div>
        <div class="exp-card">
          <div class="exp-card-glow"></div>
          <div class="exp-card-top">
            <div class="exp-role">Software Engineer</div>
            <div class="exp-company-name">Empresa Anterior</div>
          </div>
          <p class="exp-desc">Desenvolvimento de APIs escaláveis, otimização de performance e implementação de observabilidade com OpenTelemetry.</p>
          <div class="exp-stack">
            <span class="exp-chip">TypeScript</span>
            <span class="exp-chip">PostgreSQL</span>
            <span class="exp-chip">Docker</span>
            <span class="exp-chip">OpenTelemetry</span>
          </div>
        </div>
      </div>

      <!-- Entry: first role -->
      <div class="exp-entry exp-entry-last" data-exp>
        <div class="exp-year">
          <div class="exp-year-row">
            <span class="exp-year-num">2020</span>
            <span class="exp-year-month">Ago</span>
          </div>
          <span class="exp-year-label">— 2021 Jan</span>
        </div>
        <div class="exp-connector">
          <div class="exp-dot"></div>
        </div>
        <div class="exp-card">
          <div class="exp-card-glow"></div>
          <div class="exp-card-top">
            <div class="exp-role">Junior Developer</div>
            <div class="exp-company-name">Primeira Empresa</div>
          </div>
          <p class="exp-desc">Início da carreira em desenvolvimento web, aprendizado de boas práticas e primeiros projetos em produção.</p>
          <div class="exp-stack">
            <span class="exp-chip">JavaScript</span>
            <span class="exp-chip">React</span>
            <span class="exp-chip">Node.js</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── BLOG ──────────────────────────────────────────────── -->
  {recentPosts.length > 0 && (
    <section id="blog" class="section-blog">
      <div class="section-header">
        <div>
          <div class="section-overline">Blog</div>
          <h2 class="section-h2">Últimos posts</h2>
        </div>
        <a href={`${base}/blog`} class="view-all-link">
          Ver todos
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="blog-grid">
        {recentPosts.map(post => (
          <BlogCard post={post} />
        ))}
      </div>
    </section>
  )}

  <!-- ── FOOTER ────────────────────────────────────────────── -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <svg width="22" height="18" viewBox="0 0 40 32" fill="none">
          <line x1="4" y1="28" x2="4" y2="8" stroke="var(--fg-1)" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="4" y1="8" x2="20" y2="22" stroke="var(--fg-1)" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="20" y1="4" x2="4" y2="8" stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="20" y1="4" x2="36" y2="8" stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="20" y1="22" x2="36" y2="8" stroke="var(--fg-1)" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="36" y1="8" x2="36" y2="28" stroke="var(--fg-1)" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
        <span class="footer-copy">© 2026 Matheus Azevedo</span>
      </div>
      <div class="footer-links">
        <a href={`https://github.com/${SITE_CONFIG.githubUser}`} target="_blank" rel="noopener" class="footer-link">GitHub</a>
        <a href="#" class="footer-link">LinkedIn</a>
        <a href="#" class="footer-link">Email</a>
      </div>
    </div>
  </footer>

</Layout>

<style>
  /* ── NAV ── */
  /* ── HERO ── */
  #hero {
    display: flex; align-items: center;
    padding: 100px 24px 72px;
    max-width: 1100px; margin: 0 auto;
    min-height: min(680px, 90vh);
  }
  .hero-inner { max-width: 640px; }
  .hero-overline {
    display: flex; align-items: center; gap: 8px; margin-bottom: 20px;
  }
  .overline-bar { width: 24px; height: 1px; background: var(--accent); }
  .hero-overline span {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--accent);
  }
  .hero-h1 {
    font-family: var(--font-body); font-weight: 600;
    font-size: clamp(38px, 5vw, 68px);
    line-height: 1.08; letter-spacing: -0.02em;
    color: var(--fg-1); margin-bottom: 20px;
  }
  .hero-accent { color: var(--accent); }
  .hero-sub {
    font-size: clamp(15px, 1.6vw, 18px); color: var(--fg-2);
    line-height: 1.65; max-width: 480px; margin-bottom: 36px;
  }
  .hero-ctas { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
  .cta-primary {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--accent); color: #fff;
    padding: 11px 22px; border-radius: 8px;
    font-size: 14px; font-weight: 600;
    box-shadow: 0 0 28px oklch(65% 0.28 268 / 0.3);
    transition: all 150ms;
  }
  .cta-primary:hover { background: var(--accent-bright); }
  .cta-secondary {
    display: inline-flex; align-items: center; gap: 8px;
    background: transparent; color: var(--fg-2);
    padding: 11px 22px; border-radius: 8px;
    font-size: 14px; font-weight: 500;
    border: 1px solid var(--border-bright);
    transition: all 150ms;
  }
  .cta-secondary:hover { color: var(--fg-1); border-color: #4a4a70; }
  .hero-stats {
    display: flex; gap: 28px; flex-wrap: wrap;
    margin-top: 48px; padding-top: 28px;
    border-top: 1px solid var(--border);
  }
  .stat-num {
    font-family: var(--font-body); font-weight: 600;
    font-size: 26px; color: var(--fg-1); line-height: 1.2; letter-spacing: -0.02em;
  }
  .stat-label {
    font-family: var(--font-body); font-size: 12px; color: var(--fg-3); margin-top: 2px;
    font-weight: 400;
  }

  /* ── PROJECTS ── */
  .section-projects {
    padding: 80px 24px; max-width: 1100px; margin: 0 auto;
  }
  .section-header {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 40px; flex-wrap: wrap; gap: 16px;
  }
  .section-overline {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--accent); margin-bottom: 8px;
  }
  .section-h2 {
    font-family: var(--font-body); font-weight: 600;
    font-size: clamp(26px, 3.4vw, 36px);
    color: var(--fg-1); letter-spacing: -0.02em; line-height: 1.15;
  }
  .filter-pills { display: flex; gap: 6px; flex-wrap: wrap; }
  .pill {
    background: var(--bg-surface); color: var(--fg-2);
    border: 1px solid var(--border);
    padding: 6px 14px; border-radius: 9999px;
    font-size: 12px; font-weight: 600; cursor: pointer;
    transition: all 150ms; font-family: var(--font-body);
  }
  .pill-active {
    background: oklch(65% 0.28 268 / 0.15);
    color: var(--accent);
    border-color: oklch(65% 0.28 268 / 0.4);
  }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }
  .pcard {
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: 12px; padding: 22px 24px;
    text-decoration: none; cursor: pointer;
    transition: all 200ms ease;
    display: flex; flex-direction: column; gap: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }
  .pcard:hover {
    border-color: var(--border-bright);
    box-shadow: 0 4px 32px rgba(0,0,0,0.5), 0 0 0 1px var(--border-bright);
    transform: translateY(-2px);
  }
  .pcard:hover .pcard-link { color: var(--accent); }
  .pcard-top {
    display: flex; justify-content: space-between; align-items: flex-start;
  }
  .badge-active {
    background: oklch(68% 0.2 155 / 0.12); color: var(--success);
    border: 1px solid oklch(68% 0.2 155 / 0.25);
    border-radius: 6px; padding: 3px 10px;
    font-size: 11px; font-weight: 600;
    display: flex; align-items: center; gap: 5px;
  }
  .badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: currentColor; display: inline-block;
  }
  .badge-wip {
    background: oklch(75% 0.18 70 / 0.12); color: var(--warn);
    border: 1px solid oklch(75% 0.18 70 / 0.25);
    border-radius: 6px; padding: 3px 10px;
    font-size: 11px; font-weight: 600;
  }
  .badge-archived {
    background: var(--bg-elevated); color: var(--fg-3);
    border: 1px solid var(--border-bright);
    border-radius: 6px; padding: 3px 10px;
