    opacity: 0;
    transform: translateX(24px);
    transition: opacity 550ms cubic-bezier(0.22,1,0.36,1),
                transform 550ms cubic-bezier(0.22,1,0.36,1);
  }
  .exp-entry.exp-visible {
    opacity: 1;
    transform: translateX(0);
  }
  .exp-entry:nth-child(2) { transition-delay: 120ms; }
  .exp-entry:nth-child(3) { transition-delay: 240ms; }

  /* Year column — aligns its number baseline with the role title */
  .exp-year {
    text-align: right;
    padding-top: 20px;
    user-select: none;
  }
  .exp-year-row {
    display: flex;
    align-items: baseline;
    justify-content: flex-end;
    gap: 5px;
  }
  .exp-year-num {
    font-family: var(--font-body);
    font-size: 22px;
    font-weight: 700;
    color: var(--fg-4);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .exp-year-month {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    color: var(--fg-3);
    letter-spacing: 0.02em;
  }
  .exp-year-label {
    display: block;
    font-size: 11px;
    font-weight: 500;
    color: var(--fg-3);
    margin-top: 2px;
    letter-spacing: 0.03em;
  }
  .exp-year-now { color: var(--accent); }

  /* Connector column — stretches full row height so the line reaches the next entry */
  .exp-connector {
    align-self: stretch;
    display: flex;
    flex-direction: column;
    align-items: center;
    /* push dot to vertically center with role title:
       card padding-top (22px) + role font (17px/2 = 8px) - dot radius (5px) ≈ 25px */
    padding-top: 25px;
  }
  .exp-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border-bright);
    border: 2px solid var(--bg-base);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .exp-dot-active {
    background: var(--accent);
    box-shadow: 0 0 0 3px oklch(65% 0.28 268 / 0.18);
  }
  @keyframes exp-pulse {
    0%   { transform: scale(1); opacity: 0.7; }
    100% { transform: scale(2.8); opacity: 0; }
  }
  .exp-dot-ring {
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1.5px solid var(--accent);
    animation: exp-pulse 2.2s cubic-bezier(0.4,0,0.6,1) infinite;
  }
  /* Line grows to fill remaining connector height (which = full row height due to align-self: stretch) */
  .exp-line {
    width: 1px;
    flex: 1;
    background: linear-gradient(to bottom, var(--border-bright) 0%, transparent 100%);
    margin-top: 5px;
  }

  /* Card column */
  .exp-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px 26px;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
    transition: border-color 220ms ease, box-shadow 220ms ease, opacity 250ms ease, filter 250ms ease;
  }
  .exp-entry-last .exp-card {
    margin-bottom: 0;
  }
  .exp-card-glow {
    position: absolute;
    inset: 0;
    border-radius: 14px;
    background: radial-gradient(ellipse at 0% 0%, oklch(65% 0.28 268 / 0.08) 0%, transparent 55%);
    opacity: 0;
    transition: opacity 300ms ease;
    pointer-events: none;
  }
  .exp-card:hover {
    border-color: var(--border-bright);
    box-shadow: 0 4px 32px oklch(65% 0.28 268 / 0.13), 0 1px 8px rgba(0,0,0,0.4);
  }
  .exp-card:hover .exp-card-glow { opacity: 1; }
  .exp-card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 6px 16px;
    margin-bottom: 10px;
  }
  .exp-role {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 600;
    color: var(--fg-1);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .exp-company-name {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 400;
    color: var(--fg-3);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .exp-desc {
    font-size: 13.5px;
    color: var(--fg-2);
    line-height: 1.65;
    margin: 0 0 14px 0;
  }
  .exp-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .exp-chip {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--fg-2);
    background: var(--bg-elevated);
    border: 1px solid var(--border-bright);
    padding: 3px 9px;
    border-radius: 4px;
    letter-spacing: 0.03em;
    transition: color 150ms, border-color 150ms;
  }
  .exp-chip:hover {
    color: var(--accent);
    border-color: oklch(65% 0.28 268 / 0.5);
  }

  @media (max-width: 600px) {
    .exp-entry {
      grid-template-columns: 1fr;
    }
    .exp-year {
      text-align: left;
      padding-top: 0;
      display: flex;
      align-items: baseline;
      gap: 6px;
      margin-bottom: 8px;
    }
    .exp-year-num { font-size: 18px; }
    .exp-year-label { margin-top: 0; }
    .exp-connector { display: none; }
    .exp-card { margin-bottom: 16px; }
    .exp-entry-last .exp-card { margin-bottom: 0; }
  }

</style>

<script>
  // Project filter
  const pills = document.querySelectorAll<HTMLButtonElement>('.pill');
  const cards = document.querySelectorAll<HTMLElement>('.pcard');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      pills.forEach(p => p.classList.remove('pill-active'));
      pill.classList.add('pill-active');
      const filter = pill.dataset.filter;
      cards.forEach(card => {
        const show = filter === 'all' || card.dataset.status === filter;
        card.style.display = show ? 'flex' : 'none';
      });
    });
  });

  // Experience timeline: scroll-reveal
  const expObserver = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('exp-visible'); }),
    { threshold: 0.15 }
  );
  document.querySelectorAll('[data-exp]').forEach(el => expObserver.observe(el));
</script>
